---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import { CommonProblemsWithVibeCoding } from "../../components/pages/blogs/common-problems-with-vibe-coding-and-how-to-avoid-them";
import { SEO } from "astro-seo";
---

<Layout>
  <SEO
    title="Common Problems with Vibe Coding (and How to Avoid Them)"
    description="AI-assisted development has dramatically accelerated building apps, but vibe coding introduces real challenges. Here are seven common problems and how to address them."
    openGraph={{
      basic: {
        title: "Common Problems with Vibe Coding (and How to Avoid Them)",
        type: "website",
        image: "/common-problems-with-vibe-coding-and-how-to-avoid-them/hero.png",
      },
    }}
    extend={{
      link: [{ rel: "icon", href: "/icon.png" }],
      meta: [
        {
          name: "twitter:image",
          content: "/common-problems-with-vibe-coding-and-how-to-avoid-them/hero.png",
        },
        {
          name: "twitter:title",
          content: "Common Problems with Vibe Coding (and How to Avoid Them)",
        },
        {
          name: "twitter:description",
          content:
            "AI-assisted development has dramatically accelerated building apps, but vibe coding introduces real challenges. Here are seven common problems and how to address them.",
        },
      ],
    }}
  />
  <CommonProblemsWithVibeCoding client:only="react" />
</Layout>
